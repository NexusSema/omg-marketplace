{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-prd-format.sh",
          "async": true,
          "timeout": 15,
          "statusMessage": "Checking PRD format..."
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-arch-format.sh",
          "async": true,
          "timeout": 15,
          "statusMessage": "Checking architecture document format..."
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-shard-format.sh",
          "async": true,
          "timeout": 15,
          "statusMessage": "Checking shard document format..."
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-drawio-format.sh",
          "async": true,
          "timeout": 15,
          "statusMessage": "Checking draw.io file format..."
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/check-drawio-edge-collisions.py",
          "async": true,
          "timeout": 30,
          "statusMessage": "Checking draw.io edge collisions..."
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-confluence-xhtml.sh",
          "async": true,
          "timeout": 15,
          "statusMessage": "Checking Confluence XHTML format..."
        }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-spec-format.sh",
          "async": true,
          "timeout": 15,
          "statusMessage": "Checking spec format..."
        }]
      }
    ],
    "Stop": [{
      "hooks": [{
        "type": "agent",
        "prompt": "Check if the SDLC workflow task is complete: 1) All requested steps were executed 2) Output files (PRD, architecture, shard documents, or diagram files) exist and are non-empty 3) No TODO/FIXME in modified PRD, architecture, or shard files. Return {\"ok\": true} or {\"ok\": false, \"reason\": \"...\"}.",
        "model": "haiku",
        "timeout": 60
      }]
    }]
  }
}
